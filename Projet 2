<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mind & Markets</title>
  <meta
    name="description"
    content="Mind & Markets - Business et marchés financiers expliqués simplement, avec quiz, niveaux, quêtes et récompenses."
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="bg-glow glow-1"></div>
  <div class="bg-glow glow-2"></div>
  <div class="bg-glow glow-3"></div>

  <header class="site-header">
    <div class="container nav">
      <a href="#home" class="brand">
        <div class="brand-icon">↗</div>
        <div>
          <div class="brand-title">Mind & Markets</div>
          <div class="brand-subtitle">Learn • Play • Level Up</div>
        </div>
      </a>

      <nav class="nav-links">
        <a href="#lessons">Leçons</a>
        <a href="#quiz">Quiz</a>
        <a href="#quests">Quêtes</a>
        <a href="#rewards">Récompenses</a>
      </nav>

      <a class="nav-btn" href="#quiz">Commencer</a>
    </div>
  </header>

  <main>
    <section id="home" class="hero">
      <div class="container hero-grid">
        <div>
          <div class="pill">Business et marchés expliqués simplement</div>
          <h1>
            Apprends le business et les marchés
            <span>de façon ludique</span>
          </h1>
          <p class="hero-text">
            Des leçons visuelles, des QCM interactifs, des points cumulables,
            des niveaux, des quêtes et des récompenses pour progresser sans jargon.
          </p>

          <div class="hero-actions">
            <a href="#lessons" class="btn btn-primary">Explorer les leçons</a>
            <a href="#quiz" class="btn btn-secondary">Faire un quiz</a>
          </div>

          <div class="stats-grid">
            <div class="stat-card">
              <span>Niveau</span>
              <strong id="levelStat">1</strong>
            </div>
            <div class="stat-card">
              <span>Points</span>
              <strong id="pointsStat">0</strong>
            </div>
            <div class="stat-card">
              <span>Leçons terminées</span>
              <strong id="lessonsStat">0</strong>
            </div>
            <div class="stat-card">
              <span>Quiz réussis</span>
              <strong id="quizStat">0</strong>
            </div>
          </div>
        </div>

        <div class="hero-panel glass">
          <div class="hero-panel-top">
            <div>
              <div class="mini-label">Mission du jour</div>
              <h2>Comprendre les actifs</h2>
            </div>
            <div class="mini-badge">Débutant friendly</div>
          </div>

          <div class="hero-highlight">
            <div class="hero-highlight-title">Idée-clé business</div>
            <p>
              Un actif est un élément qui peut t’apporter de la valeur ou des revenus.
              Un passif te coûte de l’argent à long terme.
            </p>
            <div class="mini-asset-chart">
              <div class="mini-box good">
                <span>Actifs</span>
                <strong>↑</strong>
              </div>
              <div class="mini-box bad">
                <span>Passifs</span>
                <strong>↓</strong>
              </div>
            </div>
          </div>

          <div class="progress-card">
            <div class="progress-label-row">
              <span>Progression vers le niveau suivant</span>
              <span id="progressText">0 / 150</span>
            </div>
            <div class="progress-bar">
              <div id="progressBarFill" class="progress-fill"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container overview-grid">
        <div class="overview-card glass">
          <div class="overview-icon">⚡</div>
          <h3>Points cumulables</h3>
          <p>Chaque leçon validée et chaque quiz réussi te fait gagner des points.</p>
        </div>
        <div class="overview-card glass">
          <div class="overview-icon">🏆</div>
          <h3>Niveaux</h3>
          <p>Tu montes de niveau automatiquement selon ton total de points.</p>
        </div>
        <div class="overview-card glass">
          <div class="overview-icon">🎯</div>
          <h3>Quêtes</h3>
          <p>Des objectifs simples t’aident à savoir quoi faire ensuite.</p>
        </div>
        <div class="overview-card glass">
          <div class="overview-icon">🎁</div>
          <h3>Récompenses</h3>
          <p>Des badges et récompenses se débloquent à mesure que tu progresses.</p>
        </div>
      </div>
    </section>

    <section id="lessons" class="section">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="section-kicker">Les leçons</div>
            <h2>Cours illustrés et faciles à retenir</h2>
          </div>
          <p>
            Finance, économie et business : des contenus courts, clairs
            et visuels pour apprendre vite.
          </p>
        </div>

        <div class="filter-row">
          <button class="filter-btn active" data-filter="Tous">Tous</button>
          <button class="filter-btn" data-filter="Marchés financiers">Marchés financiers</button>
          <button class="filter-btn" data-filter="Économie">Économie</button>
          <button class="filter-btn" data-filter="Business">Business</button>
        </div>

        <div id="lessonsGrid" class="cards-grid"></div>
      </div>
    </section>

    <section id="quiz" class="section">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="section-kicker">Les QCM</div>
            <h2>Teste tes connaissances</h2>
          </div>
          <p>
            Chaque bonne réponse te rapporte des points. La progression est sauvegardée
            dans ton navigateur.
          </p>
        </div>

        <div id="quizGrid" class="quiz-grid"></div>
      </div>
    </section>

    <section id="quests" class="section">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="section-kicker">Les quêtes</div>
            <h2>Des missions pour avancer</h2>
          </div>
          <p>Complète des objectifs et réclame tes bonus.</p>
        </div>

        <div id="questsGrid" class="quests-grid"></div>
      </div>
    </section>

    <section id="rewards" class="section">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="section-kicker">Récompenses</div>
            <h2>Badges et niveaux débloqués</h2>
          </div>
          <p>Plus tu apprends, plus tu débloques d’éléments.</p>
        </div>

        <div id="rewardsGrid" class="rewards-grid"></div>
      </div>
    </section>

    <section class="section final-cta-section">
      <div class="container">
        <div class="final-cta glass">
          <div>
            <div class="section-kicker">Mind & Markets</div>
            <h2>Un site beau, utile et motivant à partager dans ta bio</h2>
            <p>
              Tu peux ensuite l’enrichir avec de nouvelles leçons, de nouveaux quiz
              et encore plus de récompenses.
            </p>
          </div>
          <div class="cta-actions">
            <a href="#lessons" class="btn btn-primary">Voir les leçons</a>
            <a href="#quiz" class="btn btn-secondary">Faire un quiz</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-row">
      <div>
        <div class="footer-title">Mind & Markets</div>
        <div class="footer-subtitle">
          Business et marchés financiers expliqués simplement.
        </div>
      </div>
      <div class="footer-links">
        <a href="#home">Accueil</a>
        <a href="#lessons">Leçons</a>
        <a href="#quiz">Quiz</a>
        <a href="#quests">Quêtes</a>
        <a href="#rewards">Récompenses</a>
      </div>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
:root {
  --bg: #07111f;
  --bg-soft: rgba(255, 255, 255, 0.05);
  --panel: #0d1727;
  --panel-2: #121e31;
  --text: #ffffff;
  --muted: #9fb0c8;
  --green: #34d399;
  --green-2: #10b981;
  --violet: #8b5cf6;
  --pink: #ec4899;
  --yellow: #fbbf24;
  --border: rgba(255, 255, 255, 0.10);
  --shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
  --radius-xl: 32px;
  --radius-lg: 24px;
  --radius-md: 18px;
  --max: 1180px;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: "Inter", sans-serif;
  background:
    radial-gradient(circle at top left, rgba(16, 185, 129, 0.08), transparent 22%),
    radial-gradient(circle at 85% 15%, rgba(139, 92, 246, 0.08), transparent 18%),
    radial-gradient(circle at 80% 80%, rgba(236, 72, 153, 0.07), transparent 18%),
    var(--bg);
  color: var(--text);
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font: inherit;
}

.container {
  width: min(var(--max), calc(100% - 32px));
  margin: 0 auto;
}

.bg-glow {
  position: fixed;
  border-radius: 999px;
  filter: blur(70px);
  opacity: 0.18;
  z-index: 0;
  pointer-events: none;
}

.glow-1 {
  width: 240px;
  height: 240px;
  background: var(--green);
  top: 60px;
  left: 20px;
}

.glow-2 {
  width: 220px;
  height: 220px;
  background: var(--violet);
  top: 140px;
  right: 40px;
}

.glow-3 {
  width: 260px;
  height: 260px;
  background: var(--pink);
  bottom: 60px;
  right: 10%;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  backdrop-filter: blur(18px);
  background: rgba(7, 17, 31, 0.72);
  border-bottom: 1px solid var(--border);
}

.nav {
  min-height: 78px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-icon {
  width: 46px;
  height: 46px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, var(--green), var(--green-2));
  color: #06111b;
  font-weight: 800;
  box-shadow: 0 16px 36px rgba(16, 185, 129, 0.28);
}

.brand-title {
  font-weight: 800;
  font-size: 1.05rem;
}

.brand-subtitle {
  font-size: 0.78rem;
  color: var(--muted);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 26px;
}

.nav-links a {
  color: #d7e0ed;
  font-size: 0.95rem;
}

.nav-links a:hover {
  color: white;
}

.nav-btn,
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 18px;
  padding: 14px 22px;
  font-weight: 700;
  border: 1px solid transparent;
  transition: 0.2s ease;
}

.nav-btn {
  background: white;
  color: #07111f;
  padding: 12px 18px;
}

.btn:hover,
.nav-btn:hover {
  transform: translateY(-1px);
}

.btn-primary {
  background: linear-gradient(135deg, var(--green), var(--green-2));
  color: #06111b;
  box-shadow: 0 18px 36px rgba(16, 185, 129, 0.25);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: white;
  border-color: var(--border);
}

.hero {
  position: relative;
  z-index: 1;
  padding: 58px 0 28px;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.06fr 0.94fr;
  gap: 28px;
  align-items: center;
}

.pill,
.section-kicker,
.mini-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  color: #b7f7dd;
}

.pill {
  background: rgba(16, 185, 129, 0.12);
  border: 1px solid rgba(52, 211, 153, 0.20);
  border-radius: 999px;
  padding: 10px 14px;
  margin-bottom: 20px;
}

.hero h1 {
  margin: 0;
  font-size: clamp(2.5rem, 5vw, 4.7rem);
  line-height: 1.02;
  letter-spacing: -0.04em;
  max-width: 780px;
}

.hero h1 span {
  color: var(--green);
}

.hero-text {
  margin: 22px 0 0;
  color: var(--muted);
  font-size: 1.05rem;
  line-height: 1.75;
  max-width: 700px;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 28px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  margin-top: 30px;
}

.stat-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 18px;
  backdrop-filter: blur(12px);
}

.stat-card span {
  display: block;
  font-size: 0.9rem;
  color: var(--muted);
}

.stat-card strong {
  display: block;
  margin-top: 10px;
  font-size: 1.9rem;
}

.glass {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border);
  backdrop-filter: blur(18px);
  box-shadow: var(--shadow);
}

.hero-panel {
  border-radius: var(--radius-xl);
  padding: 18px;
}

.hero-panel-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
}

.hero-panel h2 {
  margin: 8px 0 0;
  font-size: 1.7rem;
}

.mini-badge {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 8px 12px;
  color: #dfe7f3;
  font-size: 0.84rem;
  white-space: nowrap;
}

.hero-highlight {
  margin-top: 18px;
  border-radius: 28px;
  padding: 20px;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.16), rgba(10, 18, 32, 0.85));
  border: 1px solid rgba(52, 211, 153, 0.16);
}

.hero-highlight-title {
  font-size: 0.88rem;
  color: #c8fce8;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.hero-highlight p {
  margin: 12px 0 0;
  color: #eafbf4;
  line-height: 1.7;
}

.mini-asset-chart {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-top: 18px;
}

.mini-box {
  border-radius: 22px;
  padding: 16px;
  min-height: 100px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.mini-box.good {
  background: rgba(163, 230, 53, 0.14);
  border: 1px solid rgba(163, 230, 53, 0.18);
}

.mini-box.bad {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border);
}

.mini-box span {
  color: var(--muted);
  font-size: 0.86rem;
}

.mini-box strong {
  font-size: 2rem;
}

.progress-card {
  margin-top: 16px;
  border-radius: 24px;
  padding: 18px;
  background: rgba(0, 0, 0, 0.16);
  border: 1px solid var(--border);
}

.progress-label-row {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  color: var(--muted);
  font-size: 0.9rem;
}

.progress-bar {
  margin-top: 12px;
  height: 14px;
  width: 100%;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
}

.progress-fill {
  height: 100%;
  width: 0%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--green), var(--violet));
  transition: width 0.35s ease;
}

.section {
  position: relative;
  z-index: 1;
  padding: 34px 0 26px;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.overview-card {
  border-radius: 28px;
  padding: 24px;
}

.overview-icon {
  font-size: 1.5rem;
}

.overview-card h3 {
  margin: 14px 0 10px;
  font-size: 1.25rem;
}

.overview-card p {
  margin: 0;
  color: var(--muted);
  line-height: 1.7;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  align-items: end;
  margin-bottom: 24px;
}

.section-head h2 {
  margin: 8px 0 0;
  font-size: clamp(1.9rem, 3vw, 3rem);
  letter-spacing: -0.03em;
}

.section-head p {
  max-width: 520px;
  color: var(--muted);
  line-height: 1.7;
  margin: 0;
}

.filter-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}

.filter-btn {
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.05);
  color: #eef3fa;
  border-radius: 999px;
  padding: 11px 16px;
  cursor: pointer;
}

.filter-btn.active {
  background: linear-gradient(135deg, var(--green), var(--green-2));
  color: #07111f;
  border-color: transparent;
  font-weight: 700;
}

.cards-grid,
.quests-grid,
.rewards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.quiz-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18px;
}

.lesson-card,
.quiz-card,
.quest-card,
.reward-card {
  border-radius: 30px;
  padding: 22px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}

.lesson-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.lesson-icon {
  width: 52px;
  height: 52px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  font-size: 1.35rem;
  color: #07111f;
  font-weight: 800;
}

.gradient-green { background: linear-gradient(135deg, #34d399, #10b981); }
.gradient-orange { background: linear-gradient(135deg, #fb923c, #fbbf24); }
.gradient-cyan { background: linear-gradient(135deg, #22d3ee, #60a5fa); }
.gradient-pink { background: linear-gradient(135deg, #ec4899, #f472b6); }
.gradient-violet { background: linear-gradient(135deg, #8b5cf6, #c084fc); }
.gradient-rose { background: linear-gradient(135deg, #f43f5e, #fb7185); }
.gradient-lime { background: linear-gradient(135deg, #facc15, #a3e635); }
.gradient-indigo { background: linear-gradient(135deg, #3b82f6, #818cf8); }

.badge-soft,
.badge-level,
.badge-points,
.badge-mini {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 11px;
  font-size: 0.78rem;
  border: 1px solid var(--border);
  color: #dce6f3;
  background: rgba(255, 255, 255, 0.04);
}

.lesson-category {
  margin-top: 16px;
  color: #99f6cf;
  font-size: 0.9rem;
  font-weight: 600;
}

.lesson-card h3,
.quiz-card h3,
.quest-card h3,
.reward-card h3 {
  margin: 10px 0 0;
  font-size: 1.55rem;
  letter-spacing: -0.03em;
}

.lesson-summary,
.quiz-explanation,
.quest-text,
.reward-text {
  margin: 12px 0 0;
  color: var(--muted);
  line-height: 1.7;
}

.chart-box {
  margin-top: 16px;
  border-radius: 26px;
  padding: 16px;
  background: rgba(5, 10, 18, 0.52);
  border: 1px solid var(--border);
  min-height: 145px;
  display: grid;
  place-items: center;
}

.lesson-points {
  margin: 16px 0 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 10px;
}

.lesson-points li {
  color: #e6edf8;
  line-height: 1.55;
  font-size: 0.95rem;
  display: flex;
  gap: 10px;
}

.lesson-points li::before {
  content: "✔";
  color: #6ee7b7;
  font-weight: 700;
}

.quote-box {
  margin-top: 16px;
  border-radius: 24px;
  padding: 16px;
  background: rgba(251, 191, 36, 0.10);
  border: 1px solid rgba(251, 191, 36, 0.16);
}

.quote-box p {
  margin: 0;
  color: #fff3c2;
  line-height: 1.7;
  font-style: italic;
}

.quote-box span {
  display: block;
  margin-top: 8px;
  color: #f8dea0;
  font-size: 0.8rem;
}

.lesson-actions,
.quiz-actions,
.quest-actions {
  margin-top: 18px;
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
}

.validate-btn,
.quiz-option,
.claim-btn,
.reset-btn {
  border-radius: 16px;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: 0.2s ease;
}

.validate-btn,
.claim-btn,
.reset-btn {
  padding: 11px 14px;
  background: rgba(255, 255, 255, 0.05);
  color: white;
}

.validate-btn.done,
.claim-btn.done {
  background: linear-gradient(135deg, var(--green), var(--green-2));
  color: #07111f;
  border-color: transparent;
  font-weight: 700;
}

.quiz-card-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.quiz-options {
  margin-top: 16px;
  display: grid;
  gap: 10px;
}

.quiz-option {
  width: 100%;
  text-align: left;
  padding: 14px 16px;
  background: rgba(255, 255, 255, 0.04);
  color: #edf3fb;
}

.quiz-option:hover {
  background: rgba(255, 255, 255, 0.08);
}

.quiz-option.selected {
  border-color: rgba(255, 255, 255, 0.35);
  background: rgba(255, 255, 255, 0.10);
}

.quiz-option.correct {
  background: rgba(52, 211, 153, 0.13);
  border-color: rgba(52, 211, 153, 0.28);
  color: #c9ffea;
}

.quiz-option.wrong {
  background: rgba(248, 113, 113, 0.12);
  border-color: rgba(248, 113, 113, 0.26);
  color: #ffd5d5;
}

.quiz-feedback {
  margin-top: 16px;
  border-radius: 20px;
  padding: 14px;
  border: 1px solid var(--border);
}

.quiz-feedback.good {
  background: rgba(52, 211, 153, 0.12);
  border-color: rgba(52, 211, 153, 0.25);
}

.quiz-feedback.bad {
  background: rgba(248, 113, 113, 0.12);
  border-color: rgba(248, 113, 113, 0.25);
}

.quest-status {
  margin-top: 14px;
  color: var(--muted);
  font-size: 0.94rem;
}

.quest-status.done {
  color: #99f6cf;
}

.reward-card.locked {
  opacity: 0.72;
}

.reward-icon {
  width: 58px;
  height: 58px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  font-size: 1.5rem;
  background: rgba(255, 255, 255, 0.06);
}

.reward-card.unlocked .reward-icon {
  background: linear-gradient(135deg, var(--green), var(--green-2));
  color: #07111f;
}

.final-cta {
  border-radius: 34px;
  padding: 28px;
  display: flex;
  justify-content: space-between;
  gap: 22px;
  align-items: center;
}

.final-cta h2 {
  margin: 10px 0 0;
  font-size: clamp(1.9rem, 3vw, 3rem);
}

.final-cta p {
  color: var(--muted);
  line-height: 1.7;
  margin: 14px 0 0;
}

.cta-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.site-footer {
  position: relative;
  z-index: 1;
  border-top: 1px solid var(--border);
  margin-top: 26px;
}

.footer-row {
  min-height: 92px;
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: center;
}

.footer-title {
  font-weight: 800;
}

.footer-subtitle {
  color: var(--muted);
  margin-top: 6px;
  font-size: 0.92rem;
}

.footer-links {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  color: #dae3ef;
}

.footer-links a:hover {
  color: white;
}

svg {
  display: block;
}

@media (max-width: 1100px) {
  .hero-grid,
  .overview-grid,
  .cards-grid,
  .quests-grid,
  .rewards-grid,
  .quiz-grid,
  .stats-grid,
  .final-cta {
    grid-template-columns: 1fr;
  }

  .section-head,
  .footer-row {
    flex-direction: column;
    align-items: flex-start;
  }

  .final-cta {
    display: block;
  }

  .cta-actions {
    margin-top: 18px;
  }
}

@media (max-width: 820px) {
  .nav-links,
  .nav-btn {
    display: none;
  }

  .hero {
    padding-top: 34px;
  }

  .hero-panel {
    padding: 14px;
  }

  .lesson-card,
  .quiz-card,
  .quest-card,
  .reward-card,
  .overview-card {
    padding: 18px;
  }
}

@media (max-width: 560px) {
  .container {
    width: min(var(--max), calc(100% - 22px));
  }

  .hero h1 {
    font-size: 2.3rem;
  }

  .btn,
  .nav-btn {
    width: 100%;
  }

  .hero-actions,
  .cta-actions {
    flex-direction: column;
  }
}
